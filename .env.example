#
# osu-api-proxy-python configuration
# Copy this file to .env and adjust values as needed.
#

# Upstream osu! API base URL
UPSTREAM=https://osu.ppy.sh

# Rate limiting: requests per second
RATE_LIMIT=3

# Rate limiting: burst capacity (max requests that can fire at once)
BURST=10

# Timeouts in seconds
CONNECT_TIMEOUT=10
READ_TIMEOUT=90

# Server bind address
HOST=0.0.0.0
PORT=8727

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO